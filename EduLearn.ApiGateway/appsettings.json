{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Secret": "CHANGE_THIS_IN_PRODUCTION_MIN_32_CHARS"
  },

  "ReverseProxy": {
    "Routes": {

      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/auth/{**catch-all}" }]
      },

      "courses-route": {
        "ClusterId": "course-cluster",
        "Match": { "Path": "/api/courses/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/courses/{**catch-all}" }]
      },

      "lessons-route": {
        "ClusterId": "lesson-cluster",
        "Match": { "Path": "/api/lessons/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/lessons/{**catch-all}" }]
      },

      "enrollments-route": {
        "ClusterId": "enrollment-cluster",
        "Match": { "Path": "/api/enrollments/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/enrollments/{**catch-all}" }]
      },

      "quizzes-route": {
        "ClusterId": "assessment-cluster",
        "Match": { "Path": "/api/quizzes/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/quizzes/{**catch-all}" }]
      },

      "progress-route": {
        "ClusterId": "progress-cluster",
        "Match": { "Path": "/api/progress/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/progress/{**catch-all}" }]
      },

      "certificates-route": {
        "ClusterId": "progress-cluster",
        "Match": { "Path": "/api/certificates/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/certificates/{**catch-all}" }]
      },

      "reviews-route": {
        "ClusterId": "review-cluster",
        "Match": { "Path": "/api/reviews/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/reviews/{**catch-all}" }]
      },

      "payments-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/payments/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/payments/{**catch-all}" }]
      }
    },

    "Clusters": {

      "auth-cluster": {
        "Destinations": {
          "auth-dest": { "Address": "http://localhost:5001/" }
        }
      },

      "course-cluster": {
        "Destinations": {
          "course-dest": { "Address": "http://localhost:5002/" }
        }
      },

      "lesson-cluster": {
        "Destinations": {
          "lesson-dest": { "Address": "http://localhost:5003/" }
        }
      },

      "enrollment-cluster": {
        "Destinations": {
          "enrollment-dest": { "Address": "http://localhost:5004/" }
        }
      },

      "assessment-cluster": {
        "Destinations": {
          "assessment-dest": { "Address": "http://localhost:5005/" }
        }
      },

      "progress-cluster": {
        "Destinations": {
          "progress-dest": { "Address": "http://localhost:5006/" }
        }
      },

      "review-cluster": {
        "Destinations": {
          "review-dest": { "Address": "http://localhost:5007/" }
        }
      },

      "payment-cluster": {
        "Destinations": {
          "payment-dest": { "Address": "http://localhost:5008/" }
        }
      }
    }
  }
}
